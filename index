      state.nodes.forEach(node => {
        const isSelected = node.id === selectedNodeId;
        const isSource = node.id === connectSourceId;
        const w = node.width || 150, h = node.height || 50;
        const color = node.color || '#3b82f6';
        const textColor = node.textColor || (isDarkTheme ? '#ffffff' : '#1e293b');
        
        let strokeColor = isDarkTheme ? '#475569' : '#cbd5e1';
        let strokeWidth = '1.5', strokeDash = 'none';

        if (isSelected) { strokeColor = '#6366f1'; strokeWidth = '3.5'; } 
        else if (isSource) { strokeColor = '#ef4444'; strokeWidth = '3.5'; strokeDash = '5,5'; }

        let shapeHTML = '';
        if (node.type === 'oval') {
          shapeHTML = `<rect x="0" y="0" width="${w}" height="${h}" rx="${h/2}" ry="${h/2}" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'rect') {
          shapeHTML = `<rect x="0" y="0" width="${w}" height="${h}" rx="6" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'diamond') {
          shapeHTML = `<polygon points="${w/2},0 ${w},${h/2} ${w/2},${h} 0,${h/2}" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'parallelogram') {
          shapeHTML = `<polygon points="20,0 ${w},0 ${w-20},${h} 0,${h}" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'cylinder') {
          const rx = w/2, ry = 8;
          shapeHTML = `<path d="M 0 ${ry} A ${rx} ${ry} 0 0 0 ${w} ${ry} L ${w} ${h - ry} A ${rx} ${ry} 0 0 1 0 ${h - ry} Z" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />
            <path d="M 0 ${ry} A ${rx} ${ry} 0 0 1 ${w} ${ry}" fill="none" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />
            <path d="M 0 ${ry+5} A ${rx} ${ry} 0 0 0 ${w} ${ry+5}" fill="none" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'document') {
          const wave = 8;
          shapeHTML = `<path d="M 0 0 L ${w} 0 L ${w} ${h - wave} Q ${w * 0.75} ${h - wave * 2} ${w * 0.5} ${h - wave} T 0 ${h - wave} Z" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'hexagon') {
          shapeHTML = `<polygon points="${w*0.15},0 ${w*0.85},0 ${w},${h/2} ${w*0.85},${h} ${w*0.15},${h} 0,${h/2}" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'circle') {
          shapeHTML = `<circle cx="${w/2}" cy="${h/2}" r="${Math.min(w,h)/2}" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'folder') {
          const tw = w * 0.35, th = h * 0.2;
          shapeHTML = `<path d="M 0 0 L ${tw} 0 L ${tw+10} ${th} L ${w} ${th} L ${w} ${h} L 0 ${h} Z" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'actor') {
          shapeHTML = `
            <g stroke="${color}" stroke-width="4" stroke-linecap="round" fill="none">
              <rect x="0" y="0" width="${w}" height="${h}" fill="transparent" stroke="transparent" />
              <circle cx="${w/2}" cy="${h*0.2}" r="${h*0.15}" fill="${color}" />
              <line x1="${w/2}" y1="${h*0.35}" x2="${w/2}" y2="${h*0.65}" />
              <line x1="${w/2}" y1="${h*0.45}" x2="${w*0.1}" y2="${h*0.65}" />
              <line x1="${w/2}" y1="${h*0.45}" x2="${w*0.9}" y2="${h*0.65}" />
              <line x1="${w/2}" y1="${h*0.65}" x2="${w*0.25}" y2="${h*0.95}" />
