    function setupCanvasInteractions() {
      const svg = document.getElementById('svg-canvas');
      svg.addEventListener('contextmenu', e => e.preventDefault());
      
      svg.addEventListener('pointerdown', e => {
        if (e.target !== svg && !e.target.classList.contains('edge-clickable')) return;
        
        if (e.target === svg) {
           selectedNodeId = null; selectedEdgeId = null; render(); updatePropertiesPanel();
        }
        
        isPanning = true; svg.style.cursor = 'grabbing';
        startPanX = e.clientX - panX; startPanY = e.clientY - panY;
        try { svg.setPointerCapture(e.pointerId); } catch(err){}
      });
      
      svg.addEventListener('pointermove', e => {
        const rect = svg.getBoundingClientRect();
        if (isPanning) {
          panX = e.clientX - startPanX; panY = e.clientY - startPanY; updateTransform();
        } else if (resizingNodeId) {
          let mX = (e.clientX - rect.left - panX) / zoom;
          let mY = (e.clientY - rect.top - panY) / zoom;
          let dx = mX - resizeStartMouseX;
          let dy = mY - resizeStartMouseY;
          let nW = resizeStartW, nH = resizeStartH, nX = resizeStartX, nY = resizeStartY;

          if (resizeHandleType.includes('e')) nW = resizeStartW + dx;
          if (resizeHandleType.includes('s')) nH = resizeStartH + dy;
          if (resizeHandleType.includes('w')) { nW = resizeStartW - dx; nX = resizeStartX + dx; }
          if (resizeHandleType.includes('n')) { nH = resizeStartH - dy; nY = resizeStartY + dy; }

          if (snapToGrid) {
              nW = Math.max(MIN_NODE_W, Math.round(nW / 12) * 12);
              nH = Math.max(MIN_NODE_H, Math.round(nH / 12) * 12);
              if (resizeHandleType.includes('w')) nX = resizeStartX + (resizeStartW - nW);
              if (resizeHandleType.includes('n')) nY = resizeStartY + (resizeStartH - nH);
          } else {
              nW = Math.max(MIN_NODE_W, nW);
              nH = Math.max(MIN_NODE_H, nH);
              if (resizeHandleType.includes('w') && nW === MIN_NODE_W) nX = resizeStartX + (resizeStartW - MIN_NODE_W);
              if (resizeHandleType.includes('n') && nH === MIN_NODE_H) nY = resizeStartY + (resizeStartH - MIN_NODE_H);
          }

          const node = state.nodes.find(n => n.id === resizingNodeId);
          if (node) {
              node.width = nW; node.height = nH; node.x = nX; node.y = nY;
              render();
              if (selectedNodeId === resizingNodeId) {
                  const elW = document.getElementById('prop-width'), elH = document.getElementById('prop-height');
                  const elX = document.getElementById('prop-x'), elY = document.getElementById('prop-y');
                  if(elW) elW.value = Math.round(nW); if(elH) elH.value = Math.round(nH);
                  if(elX) elX.value = Math.round(nX); if(elY) elY.value = Math.round(nY);
              }
          }
        } else if (draggedNodeId) {
          let rX = (e.clientX - rect.left - panX) / zoom - dragStartX;
          let rY = (e.clientY - rect.top - panY) / zoom - dragStartY;
          if (snapToGrid) { rX = Math.round(rX / 12) * 12; rY = Math.round(rY / 12) * 12; }
          const node = state.nodes.find(n => n.id === draggedNodeId);
          if (node) {
            node.x = rX; node.y = rY; render();
            if (selectedNodeId === draggedNodeId) {
              const elX = document.getElementById('prop-x');
              const elY = document.getElementById('prop-y');
              if(elX) elX.value = Math.round(rX);
              if(elY) elY.value = Math.round(rY);
            }
          }
        } else if (draggedEdgeControlId) {
          let mX = (e.clientX - rect.left - panX) / zoom;
          let mY = (e.clientY - rect.top - panY) / zoom;
          if (snapToGrid) { mX = Math.round(mX / 12) * 12; mY = Math.round(mY / 12) * 12; }
          const edge = state.edges.find(e => e.id === draggedEdgeControlId);
          if (edge) { edge.controlX = mX; edge.controlY = mY; render(); }
        }
      });
      
      svg.addEventListener('pointerup', e => {
        if (isPanning) { isPanning = false; svg.style.cursor = 'grab'; try{svg.releasePointerCapture(e.pointerId);}catch(err){} }
        if (draggedNodeId) { draggedNodeId = null; try{e.target.releasePointerCapture(e.pointerId);}catch(err){} updateCodeTextarea(); }
        if (draggedEdgeControlId) { draggedEdgeControlId = null; try{e.target.releasePointerCapture(e.pointerId);}catch(err){} updateCodeTextarea(); }
        if (resizingNodeId) { resizingNodeId = null; resizeHandleType = null; try{e.target.releasePointerCapture(e.pointerId);}catch(err){} updateCodeTextarea(); }
      });
      
      document.getElementById('canvas-container').addEventListener('wheel', e => {
        e.preventDefault();
        const rect = svg.getBoundingClientRect();
        const mx = e.clientX - rect.left, my = e.clientY - rect.top;
        const fac = 1.1; let nZoom = zoom;
        if (e.deltaY < 0) nZoom = Math.min(2.5, zoom * fac); else nZoom = Math.max(0.3, zoom / fac);
        panX = mx - (mx - panX) * (nZoom / zoom); panY = my - (my - panY) * (nZoom / zoom);
        zoom = nZoom; updateTransform(); render();
      }, { passive: false });

      document.getElementById('svg-canvas').addEventListener('click', (e) => { 
        if (e.target.id === 'svg-canvas' || e.target.tagName.toLowerCase() === 'svg') {
          selectedNodeId = null; selectedEdgeId = null; render(); updatePropertiesPanel(); 
        }
      });
    }

    function zoomIn() { zoom = Math.min(2.5, zoom * 1.15); updateTransform(); render(); }
    function zoomOut() { zoom = Math.max(0.3, zoom / 1.15); updateTransform(); render(); }
    function zoomReset() { centerViewport(); render(); }

    function onResizePointerDown(e, id, type) {
      e.stopPropagation();
      resizingNodeId = id; resizeHandleType = type;
      const n = state.nodes.find(x => x.id === id);
      if (n) {
        resizeStartW = n.width || 150; resizeStartH = n.height || 50;
        resizeStartX = n.x; resizeStartY = n.y;
        const rect = document.getElementById('svg-canvas').getBoundingClientRect();
        resizeStartMouseX = (e.clientX - rect.left - panX) / zoom;
        resizeStartMouseY = (e.clientY - rect.top - panY) / zoom;
      }
      try { e.target.setPointerCapture(e.pointerId); } catch(err){}
    }

    function onNodePointerDown(e, id) {
      e.stopPropagation(); 
      if (connectMode) { handleConnectInteraction(id); return; }
      
      selectNode(id);
      draggedNodeId = id; 
      const svg = document.getElementById('svg-canvas');
      const rect = svg.getBoundingClientRect();
      const node = state.nodes.find(n => n.id === id);
      if (node) { 
        dragStartX = ((e.clientX - rect.left - panX) / zoom) - node.x; 
        dragStartY = ((e.clientY - rect.top - panY) / zoom) - node.y; 
      }
      
      try { e.target.setPointerCapture(e.pointerId); } catch(err){}
    }

    function onNodeClick(e, id) { e.stopPropagation(); if (connectMode) return; selectNode(id); }
    function selectNode(id) { selectedNodeId = id; selectedEdgeId = null; render(); updatePropertiesPanel(); }
    function selectEdge(id) { selectedEdgeId = id; selectedNodeId = null; render(); updatePropertiesPanel(); }

    function onCanvasKeyDown(e) {
      if (e.key === 'Delete' || e.key === 'Backspace') {
        if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA') return;
        if (selectedNodeId) deleteSelectedNode(); else if (selectedEdgeId) deleteSelectedEdge();
      }
    }

    function addNewNode(type) {
      const rect = document.getElementById('svg-canvas').getBoundingClientRect();
      const sx = Math.round(((rect.width / 2) - panX) / zoom - 75);
      const sy = Math.round(((rect.height / 2) - panY) / zoom - 25);
      const newId = `node-${Date.now()}`;
      
      let lbl = 'ขั้นตอนใหม่', c = '#3b82f6', w = 150, h = 50;
      if (type === 'oval') { lbl = 'เริ่มต้น/สิ้นสุด'; c = '#10b981'; }
      if (type === 'diamond') { lbl = 'ตรวจสอบ?'; c = '#f59e0b'; }
      if (type === 'cylinder') { lbl = 'ฐานข้อมูล'; c = '#06b6d4'; }
      if (type === 'document') { lbl = 'เอกสารสรุป'; c = '#8b5cf6'; }
      if (type === 'hexagon') { lbl = 'เตรียมการ'; c = '#ec4899'; w = 150; }
      if (type === 'circle') { lbl = 'A'; c = '#64748b'; w = 60; h = 60; }
      if (type === 'folder') { lbl = 'แท็บแฟ้มงาน'; c = '#3b82f6'; }
      if (type === 'actor') { lbl = 'ผู้ใช้งานระบบ'; c = '#f43f5e'; w = 60; h = 80; }
      if (type === 'subroutine') { lbl = 'โปรแกรมย่อย'; c = '#3b82f6'; w = 150; }
      if (type === 'manualInput') { lbl = 'ป้อนข้อมูล'; c = '#f59e0b'; w = 150; }
      if (type === 'display') { lbl = 'แสดงผล'; c = '#06b6d4'; w = 150; }
      if (type === 'delay') { lbl = 'หน่วงเวลา'; c = '#ef4444'; w = 120; }

      state.nodes.push({ id: newId, label: lbl, type: type, x: sx, y: sy, color: c, textColor: '#ffffff', width: w, height: h });
      render(); selectNode(newId);
    }

    function toggleConnectMode() {
      connectMode = !connectMode;
      const btn = document.getElementById('btn-connect-mode');
      const st = document.getElementById('connect-mode-status');
      const ind = document.getElementById('connect-mode-indicator');
      if (connectMode) {
        btn.classList.add('!bg-rose-500', 'text-white', 'border-rose-600');
        st.textContent = 'เลือกกล่อง...'; ind.className = 'w-2.5 h-2.5 rounded-full bg-white animate-ping';
        connectSourceId = null;
      } else {
        btn.classList.remove('!bg-rose-500', 'text-white', 'border-rose-600');
        st.textContent = 'ปิดอยู่'; ind.className = 'w-2.5 h-2.5 rounded-full bg-slate-400 dark:bg-slate-500 animate-pulse';
        connectSourceId = null;
      }
      render();
    }

    function handleConnectInteraction(nodeId) {
      if (!connectSourceId) { connectSourceId = nodeId; render(); }
      else {
        if (connectSourceId === nodeId) { connectSourceId = null; render(); return; }
        const edgeId = `edge-${Date.now()}`;
        state.edges.push({ id: edgeId, from: connectSourceId, to: nodeId, label: '', fromPort: 'auto', toPort: 'auto' });
        connectSourceId = null; toggleConnectMode(); render(); selectEdge(edgeId);
      }
    }

    function createConnectionFromSelect() {
      const from = document.getElementById('edge-source').value, to = document.getElementById('edge-target').value;
      const lbl = document.getElementById('edge-label-input').value;
      if (!from || !to) return showStatus('กรุณาเลือกต้นทางและปลายทาง', 'error');
      if (from === to) return showStatus('ไม่สามารถเชื่อมหาตัวเองได้', 'error');
      const edgeId = `edge-${Date.now()}`;
      state.edges.push({ id: edgeId, from, to, label: lbl, fromPort: 'auto', toPort: 'auto' });
      document.getElementById('edge-label-input').value = ''; render(); selectEdge(edgeId);
      showStatus('เชื่อมต่อเสร็จสมบูรณ์', 'success');
    }

    function deleteSelectedNode() {
      if (!selectedNodeId) return;
      state.edges = state.edges.filter(e => e.from !== selectedNodeId && e.to !== selectedNodeId);
      state.nodes = state.nodes.filter(n => n.id !== selectedNodeId);
      selectedNodeId = null; render(); updatePropertiesPanel(); showStatus('ลบกล่องงานเรียบร้อย', 'success');
    }

    function deleteSelectedEdge() {
      if (!selectedEdgeId) return;
      state.edges = state.edges.filter(e => e.id !== selectedEdgeId);
      selectedEdgeId = null; render(); updatePropertiesPanel(); showStatus('ลบเส้นเชื่อมต่อเรียบร้อย', 'success');
    }

    function resetSelectedEdgeCurve() {
      if (!selectedEdgeId) return;
      const e = state.edges.find(x => x.id === selectedEdgeId);
      if (e) { e.controlX = null; e.controlY = null; render(); showStatus('รีเซ็ตเส้นตรงแล้ว', 'success'); }
    }

    function updatePropertiesPanel() {
      const bdg = document.getElementById('selection-type-badge'), msg = document.getElementById('no-selection-msg');
      const fN = document.getElementById('node-properties-form'), fE = document.getElementById('edge-properties-form');
      
      fN.classList.add('hidden'); fE.classList.add('hidden'); msg.classList.remove('hidden');
      bdg.textContent = 'ไม่ได้เลือก'; bdg.className = 'text-[10px] bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-500 px-1.5 py-0.5 rounded';

      if (selectedNodeId) {
        const n = state.nodes.find(x => x.id === selectedNodeId);
        if (n) {
          bdg.textContent = 'กล่องข้อความ'; bdg.className = 'text-[10px] bg-indigo-100 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded font-medium';
          msg.classList.add('hidden'); fN.classList.remove('hidden');
          document.getElementById('prop-label').value = n.label || ''; document.getElementById('prop-width').value = n.width || 150;
          document.getElementById('prop-height').value = n.height || 50;
          document.getElementById('prop-color-custom').value = n.color || '#3b82f6';
          document.getElementById('prop-text-color-custom').value = n.textColor || '#ffffff';
        }
      } else if (selectedEdgeId) {
        const e = state.edges.find(x => x.id === selectedEdgeId);
        if (e) {
          bdg.textContent = 'เส้นโยงข้อมูล'; bdg.className = 'text-[10px] bg-emerald-100 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-1.5 py-0.5 rounded font-medium';
          msg.classList.add('hidden'); fE.classList.remove('hidden');
          document.getElementById('prop-edge-label').value = e.label || '';
          document.getElementById('prop-edge-from-port').value = e.fromPort || 'auto';
          document.getElementById('prop-edge-to-port').value = e.toPort || 'auto';
          const sn = state.nodes.find(x => x.id === e.from), tn = state.nodes.find(x => x.id === e.to);
          document.getElementById('prop-edge-from-name').textContent = sn ? sn.label.replace(/\n/g, ' ').substring(0,20) : '-';
          document.getElementById('prop-edge-to-name').textContent = tn ? tn.label.replace(/\n/g, ' ').substring(0,20) : '-';
        }
      }
    }

    function setNodeTheme(fc, tc) { if(selectedNodeId) { const n = state.nodes.find(x => x.id === selectedNodeId); if(n){ n.color = fc; n.textColor = tc; render(); updatePropertiesPanel(); } } }
    function setCustomNodeColor(v) { if(selectedNodeId) { const n = state.nodes.find(x => x.id === selectedNodeId); if(n){ n.color = v; render(); } } }
    function setCustomTextColor(v) { if(selectedNodeId) { const n = state.nodes.find(x => x.id === selectedNodeId); if(n){ n.textColor = v; render(); } } }
    function updateSelectedNodeProperty() {
      if(selectedNodeId) {
        const n = state.nodes.find(x => x.id === selectedNodeId);
        if(n){
          n.label = document.getElementById('prop-label').value; n.width = parseInt(document.getElementById('prop-width').value)||150; n.height = parseInt(document.getElementById('prop-height').value)||50; render();
        }
      }
    }
    function updateSelectedEdgeProperty() {
      if(selectedEdgeId){
        const e = state.edges.find(x => x.id === selectedEdgeId);
        if(e){ e.label = document.getElementById('prop-edge-label').value; e.fromPort = document.getElementById('prop-edge-from-port').value; e.toPort = document.getElementById('prop-edge-to-port').value; render(); }
      }
    }
    function toggleSnapToGrid() { snapToGrid = document.getElementById('snap-toggle').checked; }

    function askClearCanvas() {
      const activeTab = tabs.find(t => t.id === activeTabId);
      document.getElementById('modal-title').textContent = `ยืนยันล้างข้อมูลแท็บ "${activeTab ? activeTab.name : 'ปัจจุบัน'}"`;
      document.getElementById('modal-desc').textContent = 'คุณแน่ใจแล้วหรือไม่ว่าต้องการล้างองค์ประกอบผังงานทุกชิ้นบนแท็บนี้?';
      const btn = document.getElementById('modal-btn-confirm'), nb = btn.cloneNode(true); btn.parentNode.replaceChild(nb, btn);
      nb.addEventListener('click', () => { 
        state = { nodes: [], edges: [] }; 
        const t = tabs.find(x => x.id === activeTabId);
        if (t) t.state = state;
        selectedNodeId = null; selectedEdgeId = null; connectSourceId = null; 
        render(); updatePropertiesPanel(); showStatus('ล้างบอร์ดแผ่นงานแท็บนี้เรียบร้อยแล้ว', 'success'); closeConfirmModal(); 
      });
      const md = document.getElementById('confirm-modal'); md.classList.remove('hidden');
      setTimeout(() => { md.classList.remove('opacity-0'); md.querySelector('div').classList.remove('scale-95'); }, 10);
    }
    
    function closeConfirmModal() {
      const md = document.getElementById('confirm-modal'); md.classList.add('opacity-0'); md.querySelector('div').classList.add('scale-95');
      setTimeout(() => md.classList.add('hidden'), 350);
    }

    function showStatus(msg, type = 'success') {
      const ex = document.getElementById('status-toast'); if (ex) ex.remove();
      const t = document.createElement('div'); t.id = 'status-toast';
      t.className = `fixed bottom-36 lg:bottom-10 right-4 lg:left-1/2 lg:-translate-x-1/2 px-5 py-3 rounded-xl shadow-2xl text-xs font-semibold z-50 flex items-center gap-2 border transition-all duration-300 transform scale-95 opacity-0`;
      if (type === 'success') { t.className += ' bg-emerald-50 dark:bg-emerald-950 border-emerald-300 dark:border-emerald-500 text-emerald-700 dark:text-emerald-200'; t.innerHTML = `<span class="text-sm">✔</span> ${msg}`; } 
      else { t.className += ' bg-rose-50 dark:bg-rose-950 border-rose-300 dark:border-rose-500 text-rose-700 dark:text-rose-200'; t.innerHTML = `<span class="text-sm">✖</span> ${msg}`; }
      document.body.appendChild(t);
      setTimeout(() => { t.classList.remove('scale-95', 'opacity-0'); t.classList.add('scale-100', 'opacity-100'); }, 10);
      setTimeout(() => { t.classList.remove('scale-100', 'opacity-100'); t.classList.add('scale-95', 'opacity-0'); setTimeout(() => t.remove(), 300); }, 3500);
    }

    function validateJSONInput() {
      const codeStr = document.getElementById('code-textarea').value, pill = document.getElementById('code-status-pill');
      try {
        const p = JSON.parse(codeStr);
        if (p.nodes && p.edges) { pill.className = 'text-[10px] bg-amber-100 dark:bg-amber-500/10 border border-amber-300 dark:border-amber-500/20 text-amber-700 dark:text-amber-400 px-2 py-0.5 rounded-full font-medium flex items-center gap-1'; pill.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> แก้ไขยังไม่บันทึก'; }
        else { pill.className = 'text-[10px] bg-rose-100 dark:bg-rose-500/10 border border-rose-300 dark:border-rose-500/20 text-rose-700 dark:text-rose-400 px-2 py-0.5 rounded-full font-medium flex items-center gap-1'; pill.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> ขาดข้อมูลหลัก'; }
      } catch (err) { pill.className = 'text-[10px] bg-rose-100 dark:bg-rose-500/10 border border-rose-300 dark:border-rose-500/20 text-rose-700 dark:text-rose-400 px-2 py-0.5 rounded-full font-medium flex items-center gap-1'; pill.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> รูปแบบผิด'; }
    }

    function applyCodeFromEditor() {
      try {
        const p = JSON.parse(document.getElementById('code-textarea').value);
        if (!p.nodes || !p.edges) return showStatus('โครงสร้างต้องมีอาเรย์ nodes และ edges', 'error');
        
        state = p; 
        const t = tabs.find(x => x.id === activeTabId);
        if (t) t.state = state;
        
        selectedNodeId = null; selectedEdgeId = null; connectSourceId = null;
        render(); updatePropertiesPanel(); showStatus('นำโค้ดขึ้นผืนผ้าใบสำเร็จแล้ว!', 'success');
      } catch (err) { showStatus('เกิดข้อผิดพลาดจาก JSON: ' + err.message, 'error'); }
    }
    function copyCodeToClipboard() { document.getElementById('code-textarea').select(); try { document.execCommand('copy'); showStatus('คัดลอกโค้ดเรียบร้อย', 'success'); } catch(e){} }

    function triggerImport() { document.getElementById('file-import').click(); }

    async function importFile(event) {
      const file = event.target.files[0];
      if (!file) return;

      try {
        const text = await file.text(); 
        let parsedData = null;

        if (file.name.endsWith('.json')) {
          parsedData = JSON.parse(text);
        } else if (file.name.endsWith('.png')) {
          const magicIdx = text.lastIndexOf(MAGIC_IDENTIFIER);
          if (magicIdx !== -1) {
            const jsonStr = text.substring(magicIdx + MAGIC_IDENTIFIER.length);
            parsedData = JSON.parse(jsonStr);
          } else {
            return showStatus('ไม่พบข้อมูลโค้ดฝังแฝงในไฟล์ PNG นี้', 'error');
          }
        } else if (file.name.endsWith('.svg')) {
          const match = text.match(/<script type="application\/json" id="flowcraft-data">([\s\S]*?)<\/script>/);
          if (match && match[1]) {
            parsedData = JSON.parse(match[1]);
          } else {
            return showStatus('ไม่พบข้อมูล Flow ฝังในไฟล์ SVG นี้', 'error');
          }
        }

        if (parsedData && parsedData.nodes && parsedData.edges) {
          state = parsedData;
          const t = tabs.find(x => x.id === activeTabId);
          if (t) {
            t.state = state;
            t.name = file.name.replace(/\.[^/.]+$/, ""); // ดึงชื่อไฟล์มาตั้งเป็นชื่อแท็บด้วย
          }
          
          selectedNodeId = null; selectedEdgeId = null; connectSourceId = null;
          renderTabs();
          centerViewport(); render(); updatePropertiesPanel();
          showStatus('นำเข้าไฟล์ลงแท็บปัจจุบันสำเร็จ!', 'success');
        } else {
          showStatus('ไฟล์ข้อมูลมีโครงสร้างไม่ครบถ้วน', 'error');
        }
      } catch (err) {
        showStatus('ข้อผิดพลาดระหว่างนำเข้า: ไฟล์นี้อาจไม่ได้ถูกสร้างโดยแอปพลิเคชัน', 'error');
      }
      event.target.value = ''; // Reset
    }

    function exportSVG() {
      const svgOriginal = document.getElementById('svg-canvas');
      const clone = svgOriginal.cloneNode(true);
      clone.removeAttribute('id'); clone.setAttribute('width', '1200'); clone.setAttribute('height', '800');
      
      const content = clone.querySelector('#canvas-content');
      if (content) content.setAttribute('transform', 'translate(50, 50) scale(1)');

      const scriptTag = document.createElementNS("http://www.w3.org/2000/svg", "script");
      scriptTag.setAttribute("type", "application/json");
      scriptTag.setAttribute("id", "flowcraft-data");
      scriptTag.textContent = JSON.stringify(state);
      clone.appendChild(scriptTag);

      const activeTab = tabs.find(t => t.id === activeTabId);
      const fileName = activeTab ? activeTab.name.replace(/[^a-z0-9]/gi, '_').toLowerCase() : 'flowcraft';

      const svgData = new XMLSerializer().serializeToString(clone);
      const svgBlob = new Blob([svgData], { type: 'image/svg+xml;charset=utf-8' });
      const dl = document.createElement('a'); dl.href = URL.createObjectURL(svgBlob); dl.download = `${fileName}-${Date.now()}.svg`;
      document.body.appendChild(dl); dl.click(); document.body.removeChild(dl);
      showStatus('ดาวน์โหลดไฟล์เวกเตอร์ SVG (แก้ไขได้) สำเร็จแล้ว', 'success');
    }

    function exportPNG() {
      if (state.nodes.length === 0) return showStatus('ไม่พบกล่องงานเพื่อส่งออก', 'error');
      showStatus('กำลังประมวลผลรูปภาพ PNG...', 'success');

      const isDarkTheme = document.documentElement.classList.contains('dark');
      const bgColor = isDarkTheme ? '#020617' : '#f8fafc'; 

      const svgOriginal = document.getElementById('svg-canvas');
      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      state.nodes.forEach(n => {
        minX = Math.min(minX, n.x); minY = Math.min(minY, n.y);
        maxX = Math.max(maxX, n.x + (n.width || 150)); maxY = Math.max(maxY, n.y + (n.height || 50));
      });
      const pad = 50, width = (maxX - minX) + pad * 2, height = (maxY - minY) + pad * 2;

      const clone = svgOriginal.cloneNode(true);
      clone.setAttribute('width', width); clone.setAttribute('height', height); clone.setAttribute('viewBox', `0 0 ${width} ${height}`);
      clone.style.backgroundImage = 'none'; clone.style.backgroundColor = bgColor;

      const content = clone.querySelector('#canvas-content');
      if (content) content.setAttribute('transform', `translate(${-minX + pad}, ${-minY + pad}) scale(1)`);

      const svgData = new XMLSerializer().serializeToString(clone);
      const svgBlob = new Blob([svgData], { type: 'image/svg+xml;charset=utf-8' });
      const img = new Image();
      
      const activeTab = tabs.find(t => t.id === activeTabId);
      const fileName = activeTab ? activeTab.name.replace(/[^a-z0-9]/gi, '_').toLowerCase() : 'flowcraft';
      
      img.onload = function() {
        const cvs = document.createElement('canvas'); cvs.width = width; cvs.height = height;
        const ctx = cvs.getContext('2d');
        ctx.fillStyle = bgColor; ctx.fillRect(0, 0, width, height); ctx.drawImage(img, 0, 0);

        cvs.toBlob(blob => {
          const jsonStr = JSON.stringify(state);
          const magicText = MAGIC_IDENTIFIER + jsonStr;
          const textBlob = new Blob([magicText], { type: 'text/plain' });
          
          const finalBlob = new Blob([blob, textBlob], { type: 'image/png' });
          const dl = document.createElement('a'); dl.href = URL.createObjectURL(finalBlob); dl.download = `${fileName}-${Date.now()}.png`;
          document.body.appendChild(dl); dl.click(); document.body.removeChild(dl);
          showStatus('สร้างรูปภาพผังงาน PNG (แก้ไขได้) และดาวน์โหลดสำเร็จแล้ว!', 'success');
        }, 'image/png');
      };
      img.onerror = () => showStatus('เกิดข้อผิดพลาดในการโหลดกราฟิกรูปภาพ', 'error');
      img.src = URL.createObjectURL(svgBlob);
    }
  </script>
