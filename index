            <rect x="-4" y="-4" width="${w+8}" height="${h+8}" rx="4" fill="none" stroke="${isSelected || isSource ? strokeColor : 'transparent'}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />
          `;
        } else if (node.type === 'subroutine') {
          shapeHTML = `<rect x="0" y="0" width="${w}" height="${h}" rx="2" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />
            <line x1="15" y1="0" x2="15" y2="${h}" stroke="${strokeColor}" stroke-width="${strokeWidth}" />
            <line x1="${w-15}" y1="0" x2="${w-15}" y2="${h}" stroke="${strokeColor}" stroke-width="${strokeWidth}" />`;
        } else if (node.type === 'manualInput') {
          shapeHTML = `<polygon points="0,${h*0.25} ${w},0 ${w},${h} 0,${h}" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'display') {
          shapeHTML = `<path d="M ${w*0.15} 0 L ${w-15} 0 Q ${w} ${h/2} ${w-15} ${h} L ${w*0.15} ${h} L 0 ${h/2} Z" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        } else if (node.type === 'delay') {
          shapeHTML = `<path d="M 0 0 L ${w - h/2} 0 A ${h/2} ${h/2} 0 0 1 ${w - h/2} ${h} L 0 ${h} Z" fill="${color}" stroke="${strokeColor}" stroke-width="${strokeWidth}" stroke-dasharray="${strokeDash}" />`;
        }

        const lines = (node.label || '').split('\n');
