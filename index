        let textHTML = '';
        lines.forEach((line, i) => {
          textHTML += `<text x="${w/2}" y="${textY + (i * ls)}" text-anchor="middle" dominant-baseline="middle" font-size="${fs}" font-weight="500" fill="${textColor}" class="pointer-events-none">${line}</text>`;
        });

        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.setAttribute('class', 'node-group select-none cursor-grab');
        g.setAttribute('transform', `translate(${node.x}, ${node.y})`);
        g.innerHTML = `${shapeHTML}${textHTML}`;
        
        g.addEventListener('pointerdown', e => onNodePointerDown(e, node.id));
        g.addEventListener('click', e => onNodeClick(e, node.id));
        
        if (isSelected) {
          const hs = 8;
          const createHandle = (hx, hy, cursor, type) => {
            const hnd = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            hnd.setAttribute('x', hx - hs/2); hnd.setAttribute('y', hy - hs/2);
            hnd.setAttribute('width', hs); hnd.setAttribute('height', hs);
            hnd.setAttribute('fill', '#ffffff'); hnd.setAttribute('stroke', strokeColor);
            hnd.setAttribute('stroke-width', '1.5'); hnd.setAttribute('class', `cursor-${cursor}`);
            hnd.addEventListener('pointerdown', e => onResizePointerDown(e, node.id, type));
            return hnd;
          };
          g.appendChild(createHandle(0, 0, 'nwse-resize', 'nw'));
          g.appendChild(createHandle(w/2, 0, 'ns-resize', 'n'));
          g.appendChild(createHandle(w, 0, 'nesw-resize', 'ne'));
          g.appendChild(createHandle(w, h/2, 'ew-resize', 'e'));
          g.appendChild(createHandle(w, h, 'nwse-resize', 'se'));
          g.appendChild(createHandle(w/2, h, 'ns-resize', 's'));
          g.appendChild(createHandle(0, h, 'nesw-resize', 'sw'));
          g.appendChild(createHandle(0, h/2, 'ew-resize', 'w'));

          const delBtn = document.createElementNS('http://www.w3.org/2000/svg', 'g');
          delBtn.setAttribute('transform', `translate(${w + 12}, -12)`);
          delBtn.setAttribute('class', 'cursor-pointer hover:opacity-80 transition-opacity');
          delBtn.innerHTML = `
            <circle cx="0" cy="0" r="12" fill="#ef4444" stroke="#ffffff" stroke-width="2" class="dark:stroke-slate-900 shadow-sm" />
            <path d="M-3.5 -2.5 h7 M-2.5 -2.5 v6 a0.5 0.5 0 0 0 0.5 0.5 h4 a0.5 0.5 0 0 0 0.5 -0.5 v-6 M-1.5 -2.5 v-1 a0.5 0.5 0 0 1 0.5 -0.5 h2 a0.5 0.5 0 0 1 0.5 0.5 v1" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          `;
          delBtn.addEventListener('pointerdown', e => e.stopPropagation());
          delBtn.addEventListener('click', e => {
            e.stopPropagation();
            deleteSelectedNode();
          });
          g.appendChild(delBtn);
        }

        container.appendChild(g);
      });
    }

    function renderEdges() {
