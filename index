<!DOCTYPE html>
<html lang="th" class="dark h-full bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 transition-colors duration-300">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FlowCraft Pro - โปรแกรมสร้างผังงานอัจฉริยะ</title>
  
  <!-- นำเข้า Tailwind CSS และเปิดโหมด Class Dark Mode -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {}
      }
    }
  </script>

  <!-- กำหนดสไตล์ฟอนต์และการจัดการระบบกริดเพิ่มเล็กน้อย -->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap');
    body {
      font-family: 'Sarabun', sans-serif;
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #94a3b8;
      border-radius: 3px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #475569;
    }
  </style>
</head>
<body class="h-full flex flex-col overflow-hidden select-none bg-slate-50 dark:bg-slate-950 transition-colors duration-300">

  <!-- ================= TOP NAVIGATION BAR ================= -->
  <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-4 py-3 md:px-6 md:py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 shrink-0 shadow-sm dark:shadow-lg z-50 transition-colors duration-300">
    <div class="flex items-center gap-2.5">
      <!-- ไอคอนโลโก้ SVG ขนาดปรับตัว -->
      <div class="p-1.5 md:p-2 bg-indigo-600 rounded-lg text-white shadow-lg shadow-indigo-500/20 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
      <div>
        <h1 class="text-base md:text-xl font-bold bg-gradient-to-r from-indigo-500 to-cyan-500 dark:from-indigo-400 dark:to-cyan-400 bg-clip-text text-transparent">FlowCraft Pro</h1>
        <p class="hidden md:block text-[10px] md:text-xs text-slate-500 dark:text-slate-400">ระบบสร้างผังงานอัจฉริยะ ลากวาง ปรับขนาด และเชื่อมพอร์ตอิสระ</p>
      </div>
    </div>
    
    <div class="flex items-center gap-2 shrink-0">
      <!-- เมนูสถานะคำแนะนำดัดเส้นลอยตัว -->
      <div class="relative group">
        <button class="bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 px-3 py-1.5 rounded-lg text-[10px] md:text-xs text-slate-700 dark:text-slate-300 flex items-center gap-1.5 transition">
          <span>💡 วิธีดัดเส้นอิสระ</span>
        </button>
        <div class="absolute right-0 top-full mt-2 w-72 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-3.5 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[99]">
          <h4 class="text-xs font-bold text-indigo-500 dark:text-indigo-400 mb-1.5">💡 ปรับดัดเส้นได้อย่างใจคิด</h4>
          <ul class="text-[10px] text-slate-600 dark:text-slate-300 space-y-2 list-disc pl-3 leading-relaxed">
            <li><strong>ดัดโค้งอิสระ:</strong> คลิกที่เส้นใดก็ได้ จากนั้นลากปุ่มกลมสีม่วงเพื่อดัดโค้งความโค้งของเส้นได้อิสระ</li>
            <li><strong>บังคับจุดเชื่อม:</strong> ตั้งค่าเปลี่ยนตำแหน่งพอร์ตที่แผงควบคุมด้านซ้ายมือ</li>
          </ul>
        </div>
      </div>

      <div class="text-[10px] md:text-[11px] text-slate-500 dark:text-slate-400 flex items-center gap-2 bg-slate-100 dark:bg-slate-950/50 px-2.5 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800/80">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-ping"></span>
        <span>โหมดแก้ไขเรียลไทม์</span>
      </div>
    </div>
  </header>

  <!-- ================= MAIN LAYOUT AREA ================= -->
  <main class="flex-1 flex flex-col lg:flex-row overflow-hidden min-h-0 relative">

    <!-- 1. LEFT SIDEBAR: TOOLBOX -->
    <aside id="left-sidebar" class="hidden lg:flex flex-col w-full lg:w-80 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 shrink-0 custom-scrollbar overflow-y-auto transition-colors duration-300 z-10 shadow-lg lg:shadow-none">
      
      <!-- หมวดหมู่: สร้างบล็อกใหม่ -->
      <div class="p-4 border-b border-slate-200 dark:border-slate-800">
        <h3 class="text-xs font-bold text-indigo-500 dark:text-indigo-400 uppercase tracking-wider mb-3">1. เพิ่มกล่องงาน (Shapes)</h3>
        <div class="grid grid-cols-2 gap-2">
          <!-- วงรี -->
          <button onclick="addNewNode('oval')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <span class="w-full h-6 bg-slate-200 dark:bg-slate-600/50 rounded-full border border-slate-300 dark:border-slate-500 mb-2 flex items-center justify-center text-[9px] text-slate-500 dark:text-slate-300 group-hover:border-indigo-400">Oval</span>
            <span class="text-xs font-medium dark:text-slate-200">เริ่มต้น / สิ้นสุด</span>
          </button>
          <!-- สี่เหลี่ยม -->
          <button onclick="addNewNode('rect')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <span class="w-full h-6 bg-slate-200 dark:bg-slate-600/50 rounded-md border border-slate-300 dark:border-slate-500 mb-2 flex items-center justify-center text-[9px] text-slate-500 dark:text-slate-300 group-hover:border-indigo-400">Rectangle</span>
            <span class="text-xs font-medium dark:text-slate-200">ประมวลผล (Process)</span>
          </button>
          <!-- เงื่อนไข -->
          <button onclick="addNewNode('diamond')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <span class="w-6 h-6 rotate-45 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[8px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400"><span class="rotate-[-45deg]">Decide</span></span>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">เงื่อนไขการเลือก</span>
          </button>
          <!-- นำเข้า/ส่งออก -->
          <button onclick="addNewNode('parallelogram')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <span class="w-12 h-6 skew-x-[-15deg] bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[10px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400">I/O</span>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">นำเข้า / แสดงผล</span>
          </button>
          <!-- ฐานข้อมูล -->
          <button onclick="addNewNode('cylinder')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <span class="w-10 h-7 rounded-t-sm rounded-b-sm border-t-2 border-b-2 bg-slate-200 dark:bg-slate-600/50 border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400">DB</span>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">ฐานข้อมูล</span>
          </button>
          <!-- เอกสาร -->
          <button onclick="addNewNode('document')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <span class="w-10 h-7 border border-b-0 bg-slate-200 dark:bg-slate-600/50 border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400">Doc</span>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">เอกสารรายงาน</span>
          </button>
          <!-- การเตรียมการ -->
          <button onclick="addNewNode('hexagon')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <div class="w-12 h-6 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400" style="clip-path: polygon(15% 0, 85% 0, 100% 50%, 85% 100%, 15% 100%, 0 50%);">Prep</div>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">การเตรียมการ</span>
          </button>
          <!-- จุดเชื่อมต่อ -->
          <button onclick="addNewNode('circle')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <span class="w-7 h-7 rounded-full bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400">A</span>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">จุดเชื่อมต่อหน้า</span>
          </button>
          
          <!-- NEW 1: โปรแกรมย่อย (Subroutine) -->
          <button onclick="addNewNode('subroutine')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <div class="w-12 h-6 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 relative flex justify-center items-center group-hover:border-indigo-400 transition-colors">
                <div class="absolute left-1.5 top-0 bottom-0 border-l border-slate-300 dark:border-slate-500 transition-colors group-hover:border-indigo-400"></div>
                <div class="absolute right-1.5 top-0 bottom-0 border-r border-slate-300 dark:border-slate-500 transition-colors group-hover:border-indigo-400"></div>
                Sub
              </div>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">โปรแกรมย่อย</span>
          </button>
          
          <!-- NEW 2: ป้อนข้อมูลด้วยมือ (Manual Input) -->
          <button onclick="addNewNode('manualInput')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <div class="w-12 h-6 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400 transition-colors" style="clip-path: polygon(0 25%, 100% 0, 100% 100%, 0 100%);">Input</div>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">ป้อนข้อมูลด้วยมือ</span>
          </button>
          
          <!-- NEW 3: แสดงผล (Display) -->
          <button onclick="addNewNode('display')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <div class="w-12 h-6 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400 transition-colors" style="clip-path: polygon(15% 0, 100% 0, 100% 100%, 15% 100%, 0 50%);">Display</div>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">แสดงผลหน้าจอ</span>
          </button>
          
          <!-- NEW 4: หน่วงเวลา (Delay) -->
          <button onclick="addNewNode('delay')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <div class="w-12 h-6 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 border-l-2 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400 transition-colors" style="border-radius: 0 12px 12px 0;">Delay</div>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">หน่วงเวลา (Wait)</span>
          </button>

          <!-- โฟลเดอร์ -->
          <button onclick="addNewNode('folder')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <div class="w-10 h-7 bg-slate-200 dark:bg-slate-600/50 border border-slate-300 dark:border-slate-500 text-[9px] text-slate-500 dark:text-slate-300 flex items-center justify-center group-hover:border-indigo-400" style="clip-path: polygon(0 0, 30% 0, 40% 20%, 100% 20%, 100% 100%, 0 100%);">Tab</div>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">โฟลเดอร์/แฟ้ม</span>
          </button>
          <!-- ผู้ใช้งาน -->
          <button onclick="addNewNode('actor')" class="bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-left transition flex flex-col justify-between group">
            <div class="w-full h-8 flex items-center justify-center mb-1">
              <svg class="w-5 h-5 text-slate-500 dark:text-slate-300 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <span class="text-xs font-medium dark:text-slate-200">ผู้ใช้งาน (Actor)</span>
          </button>
        </div>
      </div>

      <!-- หมวดหมู่: สร้างเส้นเชื่อมต่อด่วน -->
      <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/40">
        <h3 class="text-xs font-bold text-indigo-500 dark:text-indigo-400 uppercase tracking-wider mb-2">2. เชื่อมโยงข้อมูล (Quick Connect)</h3>
        <p class="text-[11px] text-slate-500 dark:text-slate-400 mb-3">ระบุกล่องต้นทางและปลายทางเพื่อโยงเส้น หรือกดปุ่ม 🔗 เครื่องมือโยงเส้นด้านบน</p>
        <div class="space-y-2">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-[10px] text-slate-500 dark:text-slate-400 mb-1">จากกล่อง:</label>
              <select id="edge-source" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded px-2 py-1 text-xs text-slate-700 dark:text-white focus:outline-none focus:border-indigo-500"></select>
            </div>
            <div>
              <label class="block text-[10px] text-slate-500 dark:text-slate-400 mb-1">ไปยังกล่อง:</label>
              <select id="edge-target" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded px-2 py-1 text-xs text-slate-700 dark:text-white focus:outline-none focus:border-indigo-500"></select>
            </div>
          </div>
          <div>
            <label class="block text-[10px] text-slate-500 dark:text-slate-400 mb-1">ป้ายกำกับเส้นเชื่อม:</label>
            <input type="text" id="edge-label-input" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded px-2 py-1.5 text-xs text-slate-700 dark:text-white focus:outline-none focus:border-indigo-500" placeholder="ว่างไว้ได้ถ้าไม่มี">
          </div>
          <button onclick="createConnectionFromSelect()" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-1.5 rounded text-xs font-medium transition flex items-center justify-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            สร้างเส้นเชื่อมต่อข้อมูล
          </button>
        </div>
      </div>

      <!-- หมวดหมู่: คุณสมบัติวัตถุที่เลือก -->
      <div id="properties-panel" class="p-4 flex-1">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-bold text-emerald-500 dark:text-emerald-400 uppercase tracking-wider">3. ปรับแต่งตัวเลือกที่เลือก</h3>
          <span class="text-[10px] bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 px-1.5 py-0.5 rounded" id="selection-type-badge">ไม่ได้เลือก</span>
        </div>

        <div id="no-selection-msg" class="text-center py-6 border border-dashed border-slate-300 dark:border-slate-800 rounded-lg text-slate-400 dark:text-slate-500 text-xs">
          คลิกเลือกกล่องหรือเส้นเชื่อมบนผืนผ้าใบเพื่อเปิดใช้งานการตั้งค่าเฉพาะชิ้น
        </div>

        <!-- ฟอร์มแก้ไขคุณสมบัติบล็อก (Node Properties) -->
        <div id="node-properties-form" class="hidden space-y-3">
          <div>
            <label class="block text-[11px] text-slate-500 dark:text-slate-400 mb-1">ข้อความในกล่อง (ป้อนได้หลายบรรทัด):</label>
            <textarea id="prop-label" oninput="updateSelectedNodeProperty()" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-lg p-2 text-xs text-slate-800 dark:text-white focus:outline-none focus:border-indigo-500 custom-scrollbar h-20" placeholder="พิมพ์ข้อความที่นี่..."></textarea>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-[11px] text-slate-500 dark:text-slate-400 mb-1">ความกว้าง:</label>
              <input type="number" id="prop-width" oninput="updateSelectedNodeProperty()" class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded p-1.5 text-xs text-slate-800 dark:text-white focus:outline-none focus:border-indigo-500">
            </div>
            <div>
              <label class="block text-[11px] text-slate-500 dark:text-slate-400 mb-1">ความสูง:</label>
