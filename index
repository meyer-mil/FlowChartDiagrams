      state.edges.forEach(edge => {
        const isSelected = edge.id === selectedEdgeId;
        const details = generateDynamicEdgePath(edge);
        if (!details) return;

        const { pathData, midX, midY, start, end, cx, cy } = details;
        const strokeColor = isSelected ? '#6366f1' : (isDarkTheme ? '#64748b' : '#94a3b8');
        const strokeWidth = isSelected ? '3.5' : '2.0';
