  </main>

  <!-- ================= CUSTOM TAILWIND MODALS ================= -->
  <!-- 1. Confirm Modal -->
  <div id="confirm-modal" class="fixed inset-0 bg-slate-900/50 dark:bg-slate-950/80 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-350">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-6 rounded-2xl max-w-sm w-full mx-4 shadow-2xl transform scale-95 transition-transform duration-350">
      <div class="w-12 h-12 rounded-full bg-rose-100 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 text-rose-600 dark:text-rose-400 flex items-center justify-center mb-4">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <h3 id="modal-title" class="text-base font-bold text-slate-800 dark:text-slate-100 mb-2">ยืนยันทำรายการ</h3>
      <p id="modal-desc" class="text-xs text-slate-500 dark:text-slate-400 mb-6">คุณมั่นใจหรือไม่?</p>
      <div class="flex items-center justify-end gap-2.5">
        <button onclick="closeConfirmModal(false)" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700 rounded-lg text-xs font-medium transition">ยกเลิก</button>
        <button id="modal-btn-confirm" class="px-4 py-2 bg-rose-600 hover:bg-rose-500 text-white rounded-lg text-xs font-semibold transition shadow-md shadow-rose-600/20">ตกลง</button>
      </div>
    </div>
  </div>

  <!-- 2. Rename Tab Modal -->
  <div id="rename-modal" class="fixed inset-0 bg-slate-900/50 dark:bg-slate-950/80 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-350">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-6 rounded-2xl max-w-sm w-full mx-4 shadow-2xl transform scale-95 transition-transform duration-350">
      <h3 class="text-base font-bold text-slate-800 dark:text-slate-100 mb-2">เปลี่ยนชื่อแท็บผังงาน</h3>
      <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">โปรดระบุชื่อใหม่สำหรับงานของคุณเพื่อให้จดจำได้ง่ายขึ้น</p>
      <input type="text" id="rename-tab-input" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-800 dark:text-white focus:outline-none focus:border-indigo-500 mb-5">
      <div class="flex items-center justify-end gap-2.5">
        <button onclick="closeRenameModal()" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700 rounded-lg text-xs font-medium transition">ยกเลิก</button>
        <button onclick="confirmRenameTab()" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-xs font-semibold transition shadow-md shadow-indigo-600/20">บันทึกชื่อ</button>
      </div>
    </div>
  </div>

  <script>
    // ================= STATE, TABS & THEME MANAGEMENT =================
    // ระบบแท็บอัจฉริยะ (Multi-Tab System)
    let tabs = [];
    let activeTabId = null;
    let tabToClose = null;
    let tabToRename = null;

    // ตัวแปรสเตทของผืนผ้าใบที่อ้างอิงกับแท็บที่ทำงานอยู่
    let state = null; // จะชี้ไปที่ tabs[activeTabId].state
    let zoom = 1.0;
    let panX = 0, panY = 0;

    let isPanning = false;
    let startPanX = 0, startPanY = 0;
    let selectedNodeId = null, selectedEdgeId = null;
    let draggedNodeId = null, draggedEdgeControlId = null;
    let dragStartX = 0, dragStartY = 0;
    let resizingNodeId = null, resizeHandleType = null;
    let resizeStartW = 0, resizeStartH = 0, resizeStartX = 0, resizeStartY = 0, resizeStartMouseX = 0, resizeStartMouseY = 0;
    const MIN_NODE_W = 40, MIN_NODE_H = 30;
    let snapToGrid = true;
    let connectMode = false, connectSourceId = null;

    const MAGIC_IDENTIFIER = "___FLOWCRAFT_STATE___"; 

    window.addEventListener('load', () => {
      initTheme();
      
      // สร้างแท็บแรกเริ่ม
      const initialTabId = `tab-${Date.now()}`;
      tabs = [{ id: initialTabId, name: 'ผังงาน 1', state: { nodes: [], edges: [] }, panX: 0, panY: 0, zoom: 1.0 }];
      activeTabId = initialTabId;
      state = tabs[0].state;
      
      // โหลดเทมเพลตมาตรฐานใส่ในแท็บแรก
      loadTemplate('sequence');
      
      renderTabs();
      setupCanvasInteractions();
      switchMobileTab('canvas');
    });

    // ================= TAB MANAGEMENT FUNCTIONS =================
    
    // บันทึกตำแหน่งกล้องและการซูมของแท็บปัจจุบัน (State ถูกแก้ไขสดอยู่แล้วเพราะเป็น Pointer Ref)
    function syncTabPrimitives() {
      const activeTab = tabs.find(t => t.id === activeTabId);
      if (activeTab) {
        activeTab.panX = panX;
        activeTab.panY = panY;
        activeTab.zoom = zoom;
      }
    }

    function switchTab(tabId) {
      if (activeTabId === tabId) return;
      
      // บันทึกพิกัดของแท็บที่กำลังจะจากไป
      syncTabPrimitives();
      
      // เปลี่ยนแท็บปัจจุบัน
      activeTabId = tabId;
      const targetTab = tabs.find(t => t.id === tabId);
      if (targetTab) {
        // คืนค่าระบบสภาพแวดล้อม
        state = targetTab.state; // โยง reference ใหม่
        panX = targetTab.panX;
        panY = targetTab.panY;
        zoom = targetTab.zoom;
      }
      
      // เคลียร์การเลือกวัตถุและสถานะควบคุมต่างๆ
      selectedNodeId = null; selectedEdgeId = null; 
      draggedNodeId = null; draggedEdgeControlId = null; resizingNodeId = null;
      connectMode = false; connectSourceId = null;
      document.getElementById('btn-connect-mode').classList.remove('!bg-rose-500', 'text-white');
      document.getElementById('connect-mode-status').textContent = 'ปิดอยู่';
      
      renderTabs();
      render();
      updatePropertiesPanel();
    }

    function addNewTab() {
      syncTabPrimitives();
      const newId = `tab-${Date.now()}`;
      const newTabName = `ผังงาน ${tabs.length + 1}`;
      
      tabs.push({
        id: newId,
        name: newTabName,
        state: { nodes: [], edges: [] },
        panX: 0, panY: 0, zoom: 1.0
      });
      
      switchTab(newId);
      centerViewport();
      render();
    }

    // Modal ปิดแท็บ
    function askCloseTab(e, tabId) {
      e.stopPropagation();
      if (tabs.length <= 1) {
        showStatus('ต้องมีหน้าต่างผังงานอย่างน้อย 1 แท็บเสมอ', 'error');
        return;
      }
      tabToClose = tabId;
      const targetTab = tabs.find(t => t.id === tabId);
      document.getElementById('modal-title').textContent = 'ยืนยันปิดแท็บ ' + (targetTab ? targetTab.name : '');
      document.getElementById('modal-desc').textContent = 'คุณแน่ใจหรือไม่ว่าต้องการปิดแท็บนี้? ข้อมูลในแท็บนี้จะถูกลบหากคุณยังไม่ได้บันทึกหรือส่งออก';
      
      const btn = document.getElementById('modal-btn-confirm'), nb = btn.cloneNode(true); btn.parentNode.replaceChild(nb, btn);
      nb.addEventListener('click', () => { confirmCloseTab(); });
      
      const md = document.getElementById('confirm-modal'); md.classList.remove('hidden');
      setTimeout(() => { md.classList.remove('opacity-0'); md.querySelector('div').classList.remove('scale-95'); }, 10);
    }

    function confirmCloseTab() {
      if (!tabToClose) return;
      const idx = tabs.findIndex(t => t.id === tabToClose);
      tabs = tabs.filter(t => t.id !== tabToClose);
      
      // ถ้าปิดแท็บที่กำลังเปิดอยู่ ให้กระโดดไปแท็บใกล้เคียง
      if (activeTabId === tabToClose) {
        const nextTab = tabs[Math.max(0, idx - 1)];
        // แกล้งรีเซ็ต ID ชั่วคราวเพื่อให้ฟังก์ชัน switchTab ทำงาน
        activeTabId = null; 
        switchTab(nextTab.id);
      } else {
        renderTabs();
      }
      
      tabToClose = null;
      closeConfirmModal();
      showStatus('ปิดแท็บเรียบร้อยแล้ว', 'success');
    }

    // Modal เปลี่ยนชื่อแท็บ (Double Click)
    function askRenameTab(tabId) {
      tabToRename = tabId;
      const targetTab = tabs.find(t => t.id === tabId);
      const input = document.getElementById('rename-tab-input');
      input.value = targetTab ? targetTab.name : '';
      
      const md = document.getElementById('rename-modal'); md.classList.remove('hidden');
      setTimeout(() => { 
        md.classList.remove('opacity-0'); md.querySelector('div').classList.remove('scale-95'); 
        input.focus();
        input.select();
      }, 10);
    }

    function confirmRenameTab() {
      if (!tabToRename) return;
      const newName = document.getElementById('rename-tab-input').value.trim();
      if (newName !== '') {
        const targetTab = tabs.find(t => t.id === tabToRename);
        if (targetTab) targetTab.name = newName;
        renderTabs();
      }
      closeRenameModal();
    }

    function closeRenameModal() {
      tabToRename = null;
      const md = document.getElementById('rename-modal'); md.classList.add('opacity-0'); md.querySelector('div').classList.add('scale-95');
      setTimeout(() => md.classList.add('hidden'), 350);
    }

    function renderTabs() {
      const container = document.getElementById('tabs-container');
      let html = '';
      
      tabs.forEach(t => {
        const isActive = t.id === activeTabId;
        const bgClass = isActive 
            ? 'bg-white dark:bg-slate-950 border-t-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 rounded-t-lg shadow-[0_-2px_6px_rgba(0,0,0,0.05)] z-10' 
            : 'bg-slate-200/50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-800 border-t-2 border-transparent mt-1 rounded-t-md opacity-80 hover:opacity-100';
            
        html += `
        <div class="flex items-center gap-1.5 px-3 py-2 cursor-pointer transition-all duration-200 ${bgClass}" 
             onclick="switchTab('${t.id}')" ondblclick="askRenameTab('${t.id}')" title="ดับเบิลคลิกเพื่อเปลี่ยนชื่อ">
            <span class="text-xs font-semibold whitespace-nowrap truncate max-w-[120px] select-none pointer-events-none">${t.name}</span>
            <button onclick="askCloseTab(event, '${t.id}')" class="p-0.5 rounded-full hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-400 hover:text-rose-500 dark:hover:text-rose-400 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        `;
      });
      
      // ปุ่ม New Tab (+)
      html += `
        <button onclick="addNewTab()" title="สร้างผังงานใหม่ (New Tab)" class="ml-1 px-3 py-2 mb-1 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-slate-200 dark:hover:bg-slate-800 rounded-md transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
      `;
      container.innerHTML = html;
    }

    // ================= THEME AND RENDER =================

    function initTheme() {
      const savedTheme = localStorage.getItem('flowcraft-theme');
      if (savedTheme === 'light') { document.documentElement.classList.remove('dark'); } 
      else if (savedTheme === 'dark') { document.documentElement.classList.add('dark'); } 
      else { document.documentElement.classList.add('dark'); }
      updateGridBackground();
    }

    function toggleTheme() {
      const html = document.documentElement;
      html.classList.toggle('dark');
      const isDark = html.classList.contains('dark');
      localStorage.setItem('flowcraft-theme', isDark ? 'dark' : 'light');
      updateGridBackground();
      const arrowPath = document.querySelector('.arrow-path-default');
      if (arrowPath) { arrowPath.setAttribute('fill', isDark ? '#64748b' : '#94a3b8'); }
      renderEdges(); 
    }

    function updateGridBackground() {
      const isDark = document.documentElement.classList.contains('dark');
      const gridColor = isDark ? '#334155' : '#cbd5e1'; 
      document.getElementById('grid-background').style.backgroundImage = `radial-gradient(${gridColor} 1.5px, transparent 1.5px)`;
    }

    const templates = {
      sequence: {
        nodes: [
          { id: "node-start", label: "เริ่มต้น", type: "oval", x: 80, y: 160, color: "#10b981", textColor: "#ffffff", width: 120, height: 50 },
          { id: "node-prep", label: "ตั้งค่าระบบ", type: "hexagon", x: 260, y: 160, color: "#8b5cf6", textColor: "#ffffff", width: 140, height: 50 },
          { id: "node-process", label: "ประมวลผล", type: "rect", x: 460, y: 160, color: "#3b82f6", textColor: "#ffffff", width: 140, height: 50 },
          { id: "node-end", label: "สิ้นสุด", type: "oval", x: 660, y: 160, color: "#ef4444", textColor: "#ffffff", width: 120, height: 50 }
        ],
        edges: [
          { id: "e1", from: "node-start", to: "node-prep", label: "", fromPort: "auto", toPort: "auto", controlX: null, controlY: null },
          { id: "e2", from: "node-prep", to: "node-process", label: "", fromPort: "auto", toPort: "auto", controlX: null, controlY: null },
          { id: "e3", from: "node-process", to: "node-end", label: "สำเร็จ", fromPort: "auto", toPort: "auto", controlX: null, controlY: null }
        ]
      },
      decision: {
        nodes: [
          { id: "start", label: "ตรวจสอบพัสดุ", type: "oval", x: 300, y: 40, color: "#4f46e5", textColor: "#ffffff", width: 150, height: 50 },
          { id: "decision", label: "ของชำรุดเสียหาย\nใช่หรือไม่?", type: "diamond", x: 285, y: 140, color: "#f59e0b", textColor: "#ffffff", width: 180, height: 80 },
          { id: "reject", label: "ส่งสินค้าคืนผู้ขาย", type: "rect", x: 70, y: 280, color: "#ef4444", textColor: "#ffffff", width: 160, height: 60 },
          { id: "approve", label: "จัดเก็บเข้าสู่คลังสินค้า", type: "cylinder", x: 470, y: 280, color: "#10b981", textColor: "#ffffff", width: 160, height: 60 },
          { id: "end", label: "เสร็จสิ้นขั้นตอน", type: "oval", x: 300, y: 410, color: "#64748b", textColor: "#ffffff", width: 150, height: 50 }
        ],
        edges: [
          { id: "e1", from: "start", to: "decision", label: "", fromPort: "auto", toPort: "auto", controlX: null, controlY: null },
          { id: "e2", from: "decision", to: "reject", label: "ใช่ (ชำรุด)", fromPort: "left", toPort: "top", controlX: 130, controlY: 180 },
          { id: "e3", from: "decision", to: "approve", label: "ไม่ใช่ (ปกติ)", fromPort: "right", toPort: "top", controlX: 520, controlY: 180 },
          { id: "e4", from: "reject", to: "end", label: "", fromPort: "bottom", toPort: "left", controlX: 150, controlY: 435 },
          { id: "e5", from: "approve", to: "end", label: "", fromPort: "bottom", toPort: "right", controlX: 550, controlY: 435 }
        ]
      },
      feedback: {
        nodes: [
          { id: "actor", label: "ลูกค้าสั่งงาน", type: "actor", x: 60, y: 120, color: "#f43f5e", textColor: "#1e293b", width: 60, height: 90 },
          { id: "f-design", label: "ออกแบบระบบ (Design)", type: "folder", x: 280, y: 40, color: "#3b82f6", textColor: "#ffffff", width: 160, height: 50 },
          { id: "f-code", label: "ลงมือเขียนและทดสอบ", type: "rect", x: 280, y: 150, color: "#8b5cf6", textColor: "#ffffff", width: 160, height: 50 },
          { id: "f-eval", label: "ผู้ใช้ประเมินผลลัพธ์", type: "diamond", x: 270, y: 260, color: "#f59e0b", textColor: "#ffffff", width: 180, height: 80 },
          { id: "f-end", label: "สรุปปิดงาน", type: "document", x: 500, y: 400, color: "#10b981", textColor: "#ffffff", width: 150, height: 60 }
        ],
        edges: [
          { id: "ae", from: "actor", to: "f-code", label: "แจ้ง Request", fromPort: "right", toPort: "left", controlX: null, controlY: null },
          { id: "fe1", from: "f-design", to: "f-code", label: "", fromPort: "auto", toPort: "auto", controlX: null, controlY: null },
          { id: "fe2", from: "f-code", to: "f-eval", label: "", fromPort: "auto", toPort: "auto", controlX: null, controlY: null },
          { id: "fe3", from: "f-eval", to: "f-design", label: "ปรับปรุงเพิ่มเติม", fromPort: "left", toPort: "left", controlX: 120, controlY: 180 },
          { id: "fe4", from: "f-eval", to: "f-end", label: "ผ่านประเมิน", fromPort: "bottom", toPort: "top", controlX: null, controlY: null }
        ]
      }
    };

    function loadTemplate(key) {
      if (templates[key]) {
        state = JSON.parse(JSON.stringify(templates[key]));
        
        // ชี้สถานะของแท็บไปที่ Object ใหม่นี้
        const activeTab = tabs.find(t => t.id === activeTabId);
        if (activeTab) activeTab.state = state;
        
        selectedNodeId = null; selectedEdgeId = null; connectSourceId = null; connectMode = false;
        document.getElementById('btn-connect-mode').classList.remove('!bg-rose-500', 'text-white');
        document.getElementById('connect-mode-status').textContent = 'ปิดอยู่';
        centerViewport();
        render();
        updatePropertiesPanel();
      }
    }

    function centerViewport() {
      if (state.nodes.length === 0) { panX = 0; panY = 0; zoom = 1.0; syncTabPrimitives(); return; }
      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      state.nodes.forEach(n => {
        minX = Math.min(minX, n.x); minY = Math.min(minY, n.y);
        maxX = Math.max(maxX, n.x + (n.width || 150)); maxY = Math.max(maxY, n.y + (n.height || 50));
      });
      const centerX = (minX + maxX) / 2; const centerY = (minY + maxY) / 2;
      const rect = document.getElementById('svg-canvas').getBoundingClientRect();
      zoom = 1.0; panX = (rect.width / 2) - centerX; panY = (rect.height / 2) - centerY;
      syncTabPrimitives();
    }

    function switchMobileTab(tab) {
      const parts = { tools: 'left-sidebar', canvas: 'center-canvas', code: 'right-sidebar' };
      Object.entries(parts).forEach(([key, id]) => {
        const el = document.getElementById(id);
        const btn = document.getElementById(`tab-btn-${key}`);
        if (key === tab) {
          el.classList.remove('hidden'); el.classList.add('flex');
          btn.classList.add('text-indigo-600', 'dark:text-indigo-400', 'border-t-2', 'border-indigo-500', 'pt-0.5');
          btn.classList.remove('text-slate-500', 'dark:text-slate-400');
        } else {
          el.classList.add('hidden'); el.classList.remove('flex');
          btn.classList.remove('text-indigo-600', 'dark:text-indigo-400', 'border-t-2', 'border-indigo-500', 'pt-0.5');
          btn.classList.add('text-slate-500', 'dark:text-slate-400');
        }
      });
      if (tab === 'canvas') setTimeout(() => render(), 30);
    }

    // ================= DRAWING LOGIC =================
    
    function getPortCoords(node, portName) {
      const w = node.width || 150; const h = node.height || 50;
      switch (portName) {
        case 'top': return { x: node.x + w/2, y: node.y, dx: 0, dy: -1 };
        case 'bottom': return { x: node.x + w/2, y: node.y + h, dx: 0, dy: 1 };
        case 'left': return { x: node.x, y: node.y + h/2, dx: -1, dy: 0 };
        case 'right': return { x: node.x + w, y: node.y + h/2, dx: 1, dy: 0 };
      }
    }

    function getPortCoordsForEdge(sourceNode, targetNode, pSource, pTarget) {
      const ports = ['top', 'bottom', 'left', 'right'];
      if (pSource && pSource !== 'auto' && pTarget && pTarget !== 'auto') {
        return { start: getPortCoords(sourceNode, pSource), end: getPortCoords(targetNode, pTarget) };
      }
      if (pSource && pSource !== 'auto') {
        const start = getPortCoords(sourceNode, pSource);
        let bestTarget = 'top', minD = Infinity;
        ports.forEach(tp => {
          const tc = getPortCoords(targetNode, tp);
          const d = Math.hypot(start.x - tc.x, start.y - tc.y);
          if (d < minD) { minD = d; bestTarget = tp; }
        });
        return { start, end: getPortCoords(targetNode, bestTarget) };
      }
      if (pTarget && pTarget !== 'auto') {
        const end = getPortCoords(targetNode, pTarget);
        let bestSource = 'bottom', minD = Infinity;
        ports.forEach(sp => {
          const sc = getPortCoords(sourceNode, sp);
          const d = Math.hypot(sc.x - end.x, sc.y - end.y);
          if (d < minD) { minD = d; bestSource = sp; }
        });
        return { start: getPortCoords(sourceNode, bestSource), end };
      }
      
      let bestS = 'bottom', bestT = 'top', minD = Infinity;
      ports.forEach(sp => {
        const sc = getPortCoords(sourceNode, sp);
        ports.forEach(tp => {
          const tc = getPortCoords(targetNode, tp);
          const d = Math.hypot(sc.x - tc.x, sc.y - tc.y);
          if (d < minD) { minD = d; bestS = sp; bestT = tp; }
        });
      });
      return { start: getPortCoords(sourceNode, bestS), end: getPortCoords(targetNode, bestT) };
    }

    function generateDynamicEdgePath(edge) {
      const sNode = state.nodes.find(n => n.id === edge.from);
      const tNode = state.nodes.find(n => n.id === edge.to);
      if (!sNode || !tNode) return null;

      const { start, end } = getPortCoordsForEdge(sNode, tNode, edge.fromPort, edge.toPort);
      let cx = edge.controlX, cy = edge.controlY;
      if (cx === undefined || cx === null || cy === undefined || cy === null) {
        cx = (start.x + end.x) / 2; cy = (start.y + end.y) / 2;
      }
      const pathData = `M ${start.x} ${start.y} Q ${cx} ${cy} ${end.x} ${end.y}`;
      const midX = 0.25 * start.x + 0.5 * cx + 0.25 * end.x;
      const midY = 0.25 * start.y + 0.5 * cy + 0.25 * end.y;
      return { pathData, midX, midY, start, end, cx, cy };
    }

